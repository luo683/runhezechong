generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  phone         String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  reviews       Review[]
  consultations Consultation[]
  memberships   Membership[]
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  items           Json
  totalAmount     Int
  status          String   @default("pending")
  shippingAddress Json?
  paymentMethod   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  petName   String
  petType   String
  product   String
  rating    Int
  content   String
  createdAt DateTime @default(now())
}

model Consultation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  petType   String?
  petAge    String?
  messages  Json
  createdAt DateTime @default(now())
}

model Membership {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  planId    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}
